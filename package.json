{
  "name": "agentic-pay",
  "version": "1.0.0",
  "description": "Multi-agent BSV payment system — Agentic Pay Hackathon",
  "private": true,
  "workspaces": [
    "agents/*",
    "mcp-server",
    "ui",
    "shared"
  ],
  "scripts": {
    "dev": "docker-compose -f infra/docker/docker-compose.dev.yml up",
    "build": "npm run build --workspaces",
    "start": "docker-compose -f infra/docker/docker-compose.prod.yml up",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx",
    "setup:wallets": "ts-node scripts/setup-wallets.ts",
    "fund:testnet": "ts-node scripts/fund-testnet.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
